{
  "name": "better-seo-js-monorepo",
  "private": true,
  "description": "Monorepo for better-seo.js — see internal-docs/ and PACKAGE.md",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build -w better-seo.js && npm run build -w better-seo-assets && npm run build -w better-seo-cli && npm run build -w @better-seo/next && npm run build -w nextjs-app",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run build && npm run format:check && npm run lint && npm run typecheck && npm run test:coverage",
    "ci": "npm run check && npm run test:e2e && npm run size",
    "commit": "git-cz",
    "commitlint": "commitlint --edit",
    "commitlint:last": "commitlint --last --verbose",
    "commitlint:since-tag": "commitlint --from-last-tag --to HEAD --verbose",
    "changeset": "changeset",
    "release:version": "changeset version",
    "release:publish": "npm run build && changeset publish",
    "prepare": "husky",
    "size": "npm run size -w better-seo.js"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git",
      "useEmoji": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@size-limit/file": "^12.0.1",
    "commitizen": "^4.3.1",
    "cz-git": "^1.12.0",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.3",
    "size-limit": "^12.0.1",
    "tsup": "^8.3.6",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.24.1",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "packages/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "examples/**/*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.{md,json,yml,yaml,mjs,cjs}": [
      "prettier --write"
    ]
  }
}
