{
  "name": "better-seo.js",
  "version": "0.0.0",
  "private": true,
  "description": "Zero-runtime-dep SEO document model, merge, JSON-LD serialization — see internal-docs/ARCHITECTURE.md",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {},
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "size": "size-limit",
    "audit": "npm audit --audit-level=high"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "18 KB"
    }
  ],
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "tsup": "^8.3.6",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
