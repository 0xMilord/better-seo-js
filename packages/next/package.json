{
  "name": "@better-seo/next",
  "version": "0.0.1",
  "description": "Next.js adapter for better-seo.js — Metadata, voilà `seo()` — see internal-docs/FEATURES.md N1–N10",
  "license": "MIT",
  "type": "module",
  "sideEffects": true,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./json-ld": {
      "types": "./dist/json-ld.d.ts",
      "import": "./dist/json-ld.js",
      "require": "./dist/json-ld.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@better-seo/core": "file:../core"
  },
  "peerDependencies": {
    "next": ">=14.2.0",
    "react": ">=18.2.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": false
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "audit": "npm audit --audit-level=high"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/react": "^19.0.8",
    "@vitest/coverage-v8": "^3.0.6",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  }
}
