{
  "name": "better-seo-assets",
  "version": "0.0.0",
  "private": true,
  "description": "Optional OG images and PWA assets for better-seo.js — see internal-docs/Roadmap.md Wave 2+",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@resvg/resvg-js": "^2.6.2",
    "react": "^19.0.0",
    "satori": "^0.26.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.8",
    "@vitest/coverage-v8": "^4.1.2",
    "image-size": "^2.0.2",
    "tsup": "^8.3.6",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
